# generic files to ignore
.*

# Fork CI: the broad `.*` above hides .github; re-include the workflows.
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Editors
.vscode/*
.claude/*

# Python virtual environment
.venv/
.python-version


# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Varius extensions
*.log
*.tmp
*.DS_Store

# Sphinx documentation
build/

# Translation repository
locale/

# Patchs
*.orig
*.rej
*.diff
*.patch
